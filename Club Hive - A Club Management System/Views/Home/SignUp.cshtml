@{
    ViewData["Title"] = "Sign Up";
}

<div class="container py-4">
    <div class="text-center mb-4">
        <h1 class="display-5">Create Your Club Hive Account</h1>
        <p class="lead mb-0">Pick the role that best matches how you will use Club Hive.</p>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <h3 class="card-title h4">Student</h3>
                    <p class="card-text flex-grow-1">
                        Join clubs and take part in events to stay connected with campus life, school activities, and extracurricular communities.
                    </p>
                    <a href="#" class="btn btn-outline-primary mt-auto">Select Student</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <h3 class="card-title h4">Club Executive</h3>
                    <p class="card-text flex-grow-1">
                        Create and lead clubs, organize events, and manage member engagement so students with shared interests can build strong communities.
                    </p>
                    <a asp-controller="Home" asp-action="ClubExecutiveSignUp" class="btn btn-outline-success mt-auto">Select Club Executive</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <h3 class="card-title h4">Admin</h3>
                    <p class="card-text flex-grow-1">
                        Oversee Club Hive operations, approve clubs and events, and ensure platform policies and event logistics are handled consistently.
                    </p>
                    <a href="#" class="btn btn-outline-warning mt-auto">Select Admin</a>
                </div>
            </div>
        </div>
    </div>
</div>
