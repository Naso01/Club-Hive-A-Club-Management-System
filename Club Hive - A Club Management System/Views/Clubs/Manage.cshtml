@model List<ClubHive.Models.Club>

@{
    ViewData["Title"] = "Manage Clubs";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="mb-0">Managed Clubs</h1>
        <a asp-controller="Clubs" asp-action="Create" class="btn btn-primary">Create Club</a>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success" role="alert">
            @successMessage
        </div>
    }

    @if (Model == null || !Model.Any())
    {
        <p class="text-muted">No Clubs Available</p>
    }
    else
    {
        <div class="row g-3">
            @foreach (var club in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm">
                        <button class="btn btn-link text-decoration-none text-start p-0 border-0 rounded-top" type="button" data-bs-toggle="collapse" data-bs-target="#club-actions-@club.Id" aria-expanded="false" aria-controls="club-actions-@club.Id">
                        @if (!string.IsNullOrWhiteSpace(club.ImageUrl))
                        {
                            <img src="@club.ImageUrl" class="card-img-top" alt="@club.Name" style="max-height: 200px; object-fit: cover;" />
                        }
                        <div class="card-body">
                            <h2 class="h5 card-title">@club.Name</h2>
                            <p class="card-text">@(string.IsNullOrWhiteSpace(club.Description) ? "No description provided." : club.Description)</p>
                            <p class="text-primary small mb-0">Click card for options</p>
                        </div>
                        </button>
                        <div class="collapse px-3 pb-3" id="club-actions-@club.Id">
                            <div class="d-flex gap-2">
                                <a asp-controller="Clubs" asp-action="Edit" asp-route-id="@club.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                <form asp-controller="Clubs" asp-action="Delete" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@club.Id" />
                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger"
                                            data-bs-toggle="modal"
                                            data-bs-target="#confirmDeleteModal"
                                            data-club-id="@club.Id"
                                            data-club-name="@club.Name">
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-labelledby="confirmDeleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5" id="confirmDeleteModalLabel">Delete Club</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-1">Are you sure you want to delete this club?</p>
                <p class="mb-0 text-danger">This is a permanent action.</p>
                <p id="deleteClubName" class="mt-3 fw-semibold mb-0"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <form asp-controller="Clubs" asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="deleteClubIdInput" />
                    <button type="submit" class="btn btn-danger">Delete Club</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const deleteModal = document.getElementById("confirmDeleteModal");
            const deleteClubIdInput = document.getElementById("deleteClubIdInput");
            const deleteClubName = document.getElementById("deleteClubName");

            if (!deleteModal || !deleteClubIdInput || !deleteClubName) {
                return;
            }

            deleteModal.addEventListener("show.bs.modal", (event) => {
                const triggerButton = event.relatedTarget;
                if (!triggerButton) {
                    return;
                }

                const clubId = triggerButton.getAttribute("data-club-id");
                const clubName = triggerButton.getAttribute("data-club-name");

                deleteClubIdInput.value = clubId ?? "";
                deleteClubName.textContent = clubName ? `Club: ${clubName}` : "";
            });
        })();
    </script>
}
