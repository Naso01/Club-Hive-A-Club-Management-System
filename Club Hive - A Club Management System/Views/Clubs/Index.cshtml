@model List<ClubHive.Models.Club>

@{
    ViewData["Title"] = "Clubs";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="mb-0">All Clubs</h1>
        <a asp-controller="Clubs" asp-action="Create" class="btn btn-primary">Create Club</a>
    </div>

    @if (Model == null || !Model.Any())
    {
        <p class="text-muted">No clubs have been created yet.</p>
    }
    else
    {
        <div class="row g-3">
            @foreach (var club in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm">
                        @if (!string.IsNullOrWhiteSpace(club.ImageUrl))
                        {
                            <img src="@club.ImageUrl" class="card-img-top" alt="@club.Name" style="max-height: 200px; object-fit: cover;" />
                        }
                        <div class="card-body">
                            <h2 class="h5 card-title">@club.Name</h2>
                            <p class="card-text">@(string.IsNullOrWhiteSpace(club.Description) ? "No description provided." : club.Description)</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
